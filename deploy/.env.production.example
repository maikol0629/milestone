# ─── Imágenes (desde GitHub Container Registry) ────────
# El workflow .github/workflows/docker.yml las construye y
# las sube a ghcr.io al pushear a main.
MILESTONE_API_IMAGE=ghcr.io/maikol0629/milestone-api:latest
MILESTONE_WEB_IMAGE=ghcr.io/maikol0629/milestone-web:latest

# ─── Postgres ───────────────────────────────────────────
POSTGRES_USER=milestone
POSTGRES_PASSWORD=cambia-esto-por-una-contrasena-segura
POSTGRES_DB=milestone

# ─── JWT ────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-de-64-caracteres-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ────────────────────────────────────────────────
NODE_ENV=production
SENTRY_DSN=

# ─── CORS ───────────────────────────────────────────────
# Misma URL que usa el navegador para cargar la web
# Como Nginx sirve web y API en el mismo origen, el navegador
# ni siquiera necesita CORS, pero el backend lo exige igual.
CORS_ORIGIN=http://<IP_DEL_VPS>

# ─── Web (build args - se hornean en la imagen) ─────────
# El navegador llama al API en la misma URL que la web
# porque Nginx rutea /api/* al backend.
# Este valor debe coincidir con el GitHub variable
# NEXT_PUBLIC_API_URL que usa el workflow docker.yml.
NEXT_PUBLIC_API_URL=http://<IP_DEL_VPS>/api
NEXT_PUBLIC_SENTRY_DSN=
