{
  "name": "milestone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Milestone — plataforma de gestión de objetivos, proyectos y tiempo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.61.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import-x": "^4.17.0",
    "globals": "^17.7.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.30.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "pg": "^8.22.0"
  }
}
