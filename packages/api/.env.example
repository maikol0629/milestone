# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/milestone

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Sentry (opcional — dejar vacío para deshabilitar)
SENTRY_DSN=
